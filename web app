<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daily Log — Task Manager</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap');

:root{
  --bg: #10161d;
  --surface: #171f28;
  --surface-2: #1d2732;
  --grid-line: rgba(255,255,255,0.045);
  --border: #2a3542;
  --text: #eef1f4;
  --text-dim: #97a3af;
  --text-faint: #5b6672;
  --amber: #ffb454;
  --amber-dim: #8c6a3a;
  --mint: #5ec9a3;
  --mint-dim: #3c6656;
  --rose: #e8607a;
  --rose-dim: #7a3d47;
}

*{box-sizing:border-box;}

html,body{
  margin:0;
  padding:0;
  background:var(--bg);
  color:var(--text);
  font-family:'Inter',sans-serif;
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 28px 28px;
  min-height:100vh;
}

.wrap{
  max-width:640px;
  margin:0 auto;
  padding:48px 24px 80px;
}

/* ---- Header / log sheet title ---- */
header{
  margin-bottom:28px;
  border-bottom:1px solid var(--border);
  padding-bottom:20px;
}
.eyebrow{
  font-family:'JetBrains Mono',monospace;
  font-size:11px;
  letter-spacing:0.18em;
  color:var(--amber);
  text-transform:uppercase;
  margin:0 0 8px;
}
h1{
  font-family:'JetBrains Mono',monospace;
  font-size:26px;
  font-weight:700;
  margin:0 0 6px;
  letter-spacing:-0.01em;
}
.date-line{
  font-family:'JetBrains Mono',monospace;
  font-size:13px;
  color:var(--text-dim);
  margin:0;
}

/* ---- Counts ---- */
.counts{
  display:flex;
  gap:18px;
  margin-top:18px;
  font-family:'JetBrains Mono',monospace;
  font-size:12px;
}
.count-chip{
  display:flex;
  align-items:center;
  gap:7px;
  padding:6px 12px;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:3px;
  color:var(--text-dim);
}
.count-chip .dot{
  width:7px;height:7px;border-radius:50%;
  flex-shrink:0;
}
.count-chip.pending .dot{background:var(--amber);}
.count-chip.done .dot{background:var(--mint);}
.count-chip b{color:var(--text);font-weight:600;}

/* ---- Input row: terminal prompt ---- */
.entry-row{
  display:flex;
  align-items:center;
  gap:0;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:4px;
  margin:26px 0 34px;
  overflow:hidden;
  transition:border-color .15s ease;
}
.entry-row:focus-within{
  border-color:var(--amber-dim);
}
.prompt-glyph{
  font-family:'JetBrains Mono',monospace;
  color:var(--amber);
  font-size:15px;
  padding:0 4px 0 16px;
  user-select:none;
}
#task-input{
  flex:1;
  background:transparent;
  border:none;
  outline:none;
  color:var(--text);
  font-family:'JetBrains Mono',monospace;
  font-size:14px;
  padding:14px 8px;
}
#task-input::placeholder{
  color:var(--text-faint);
}
#add-btn{
  background:var(--amber);
  color:#1a1206;
  border:none;
  font-family:'JetBrains Mono',monospace;
  font-weight:700;
  font-size:12px;
  letter-spacing:0.06em;
  text-transform:uppercase;
  padding:14px 20px;
  cursor:pointer;
  transition:background .15s ease, transform .1s ease;
}
#add-btn:hover{background:#ffc978;}
#add-btn:active{transform:scale(0.97);}
#add-btn:disabled{background:var(--surface-2);color:var(--text-faint);cursor:not-allowed;}

/* ---- Section labels ---- */
.section-label{
  font-family:'JetBrains Mono',monospace;
  font-size:11px;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:var(--text-faint);
  margin:32px 0 12px;
  display:flex;
  align-items:center;
  gap:10px;
}
.section-label::after{
  content:'';
  flex:1;
  height:1px;
  background:var(--border);
}
.section-label.pending-label{color:var(--amber);}
.section-label.done-label{color:var(--mint);}

/* ---- Task list ---- */
ul.task-list{
  list-style:none;
  margin:0;
  padding:0;
}
.task{
  display:flex;
  align-items:flex-start;
  gap:12px;
  background:var(--surface);
  border:1px solid var(--border);
  border-left:3px solid var(--amber);
  border-radius:3px;
  padding:13px 14px;
  margin-bottom:8px;
  animation: slideIn .22s ease;
}
.task.done{
  border-left-color:var(--mint);
  opacity:0.68;
}
@keyframes slideIn{
  from{opacity:0; transform:translateY(-6px);}
  to{opacity:1; transform:translateY(0);}
}

.line-no{
  font-family:'JetBrains Mono',monospace;
  font-size:11px;
  color:var(--text-faint);
  padding-top:3px;
  min-width:22px;
  text-align:right;
  user-select:none;
}

.check-btn{
  flex-shrink:0;
  width:19px;height:19px;
  border-radius:4px;
  border:1.5px solid var(--amber-dim);
  background:transparent;
  cursor:pointer;
  margin-top:2px;
  padding:0;
  display:flex;
  align-items:center;
  justify-content:center;
  transition:border-color .15s, background .15s;
}
.task.done .check-btn{
  border-color:var(--mint);
  background:var(--mint);
}
.check-btn svg{
  width:11px;height:11px;
  opacity:0;
  transition:opacity .12s;
}
.task.done .check-btn svg{opacity:1;}
.check-btn svg path{
  stroke:#0d1a15;
  stroke-width:3;
  fill:none;
  stroke-linecap:round;
  stroke-linejoin:round;
}

.task-body{
  flex:1;
  min-width:0;
}
.task-text{
  font-size:14.5px;
  line-height:1.45;
  color:var(--text);
  word-break:break-word;
}
.task.done .task-text{
  text-decoration:line-through;
  color:var(--text-dim);
}
.task-time{
  font-family:'JetBrains Mono',monospace;
  font-size:10.5px;
  color:var(--text-faint);
  margin-top:4px;
}

.edit-input{
  width:100%;
  background:var(--surface-2);
  border:1px solid var(--amber-dim);
  border-radius:3px;
  color:var(--text);
  font-family:'Inter',sans-serif;
  font-size:14.5px;
  padding:6px 8px;
  outline:none;
}

.task-actions{
  display:flex;
  gap:6px;
  flex-shrink:0;
}
.icon-btn{
  background:transparent;
  border:1px solid var(--border);
  border-radius:3px;
  color:var(--text-faint);
  width:26px;height:26px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:border-color .15s, color .15s, background .15s;
}
.icon-btn:hover{
  border-color:var(--amber-dim);
  color:var(--amber);
}
.icon-btn.delete:hover{
  border-color:var(--rose-dim);
  color:var(--rose);
  background:rgba(232,96,122,0.08);
}
.icon-btn svg{width:13px;height:13px;}

/* ---- Empty state ---- */
.empty-state{
  font-family:'JetBrains Mono',monospace;
  font-size:12.5px;
  color:var(--text-faint);
  padding:20px 14px;
  border:1px dashed var(--border);
  border-radius:3px;
  text-align:center;
}

/* ---- Loading ---- */
.loading-msg{
  font-family:'JetBrains Mono',monospace;
  font-size:12px;
  color:var(--text-faint);
  padding:20px 0;
}

/* Focus visibility for accessibility */
button:focus-visible, input:focus-visible{
  outline:2px solid var(--amber);
  outline-offset:1px;
}

@media (prefers-reduced-motion: reduce){
  .task{animation:none;}
  * {transition:none !important;}
}

@media (max-width:480px){
  .wrap{padding:32px 16px 60px;}
  h1{font-size:22px;}
  .task{padding:11px 10px;}
}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <p class="eyebrow">Daily Log</p>
    <h1>Task Manager</h1>
    <p class="date-line" id="date-line"></p>
    <div class="counts">
      <div class="count-chip pending"><span class="dot"></span><span><b id="pending-count">0</b> pending</span></div>
      <div class="count-chip done"><span class="dot"></span><span><b id="done-count">0</b> completed</span></div>
    </div>
  </header>

  <div class="entry-row">
    <span class="prompt-glyph">&gt;</span>
    <input type="text" id="task-input" placeholder="log a new task and press enter…" maxlength="200" autocomplete="off">
    <button id="add-btn">Add task</button>
  </div>

  <div id="app-body">
    <div class="loading-msg">reading log…</div>
  </div>
</div>

<script>
(function(){
  const inputEl = document.getElementById('task-input');
  const addBtn = document.getElementById('add-btn');
  const appBody = document.getElementById('app-body');
  const pendingCountEl = document.getElementById('pending-count');
  const doneCountEl = document.getElementById('done-count');
  const dateLineEl = document.getElementById('date-line');

  let tasks = [];
  let ready = false;

  dateLineEl.textContent = new Date().toLocaleDateString(undefined, {
    weekday:'long', year:'numeric', month:'long', day:'numeric'
  });

  function uid(){
    return 't_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2,8);
  }

  function fmtTime(iso){
    if(!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString(undefined,{month:'short', day:'numeric'}) + ' · ' +
           d.toLocaleTimeString(undefined,{hour:'numeric', minute:'2-digit'});
  }

  async function loadTasks(){
    try{
      const res = await window.storage.get('tasks', false);
      if(res && res.value){
        tasks = JSON.parse(res.value);
      }
    }catch(e){
      tasks = [];
    }
    ready = true;
    render();
  }

  async function saveTasks(){
    try{
      await window.storage.set('tasks', JSON.stringify(tasks), false);
    }catch(e){
      console.error('Could not save tasks', e);
    }
  }

  function addTask(){
    const text = inputEl.value.trim();
    if(!text) return;
    tasks.unshift({
      id: uid(),
      text: text,
      completed: false,
      createdAt: new Date().toISOString(),
      completedAt: null
    });
    inputEl.value = '';
    render();
    saveTasks();
  }

  function toggleComplete(id){
    const t = tasks.find(x => x.id === id);
    if(!t) return;
    t.completed = !t.completed;
    t.completedAt = t.completed ? new Date().toISOString() : null;
    render();
    saveTasks();
  }

  function deleteTask(id){
    tasks = tasks.filter(x => x.id !== id);
    render();
    saveTasks();
  }

  function startEdit(id){
    tasks = tasks.map(t => t.id === id ? {...t, editing:true} : {...t, editing:false});
    render();
  }

  function commitEdit(id, newText){
    const t = tasks.find(x => x.id === id);
    if(!t) return;
    const trimmed = newText.trim();
    if(trimmed){
      t.text = trimmed;
    }
    t.editing = false;
    render();
    saveTasks();
  }

  function cancelEdit(id){
    const t = tasks.find(x => x.id === id);
    if(t) t.editing = false;
    render();
  }

  function checkIconSVG(){
    return '<svg viewBox="0 0 12 12"><path d="M2 6.2L4.7 9L10 3"/></svg>';
  }

  function editIconSVG(){
    return '<svg viewBox="0 0 16 16" fill="none"><path d="M11.5 2.5l2 2L5 13l-2.6.6.6-2.6L11.5 2.5z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  }

  function deleteIconSVG(){
    return '<svg viewBox="0 0 16 16" fill="none"><path d="M3 4.5h10M6.5 4.5V3a1 1 0 0 1 1-1h1a1 1 0 0 1 1 1v1.5M4.5 4.5l.6 8a1 1 0 0 0 1 .9h3.8a1 1 0 0 0 1-.9l.6-8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  }

  function taskRowHTML(t, index){
    if(t.editing){
      return `
        <li class="task ${t.completed ? 'done' : ''}" data-id="${t.id}">
          <span class="line-no">${String(index+1).padStart(2,'0')}</span>
          <button class="check-btn" data-action="toggle" aria-label="Toggle complete">${checkIconSVG()}</button>
          <div class="task-body">
            <input class="edit-input" data-action="edit-input" value="${escapeAttr(t.text)}" maxlength="200">
          </div>
          <div class="task-actions">
            <button class="icon-btn" data-action="save-edit" aria-label="Save">${checkIconSVG()}</button>
          </div>
        </li>`;
    }
    return `
      <li class="task ${t.completed ? 'done' : ''}" data-id="${t.id}">
        <span class="line-no">${String(index+1).padStart(2,'0')}</span>
        <button class="check-btn" data-action="toggle" aria-label="${t.completed ? 'Mark pending' : 'Mark complete'}">${checkIconSVG()}</button>
        <div class="task-body">
          <div class="task-text">${escapeHtml(t.text)}</div>
          <div class="task-time">${t.completed ? 'done ' + fmtTime(t.completedAt) : 'added ' + fmtTime(t.createdAt)}</div>
        </div>
        <div class="task-actions">
          <button class="icon-btn" data-action="edit" aria-label="Edit task">${editIconSVG()}</button>
          <button class="icon-btn delete" data-action="delete" aria-label="Delete task">${deleteIconSVG()}</button>
        </div>
      </li>`;
  }

  function escapeHtml(str){
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
  function escapeAttr(str){
    return escapeHtml(str).replace(/"/g,'&quot;');
  }

  function render(){
    if(!ready){
      appBody.innerHTML = '<div class="loading-msg">reading log…</div>';
      return;
    }
    const pending = tasks.filter(t => !t.completed);
    const done = tasks.filter(t => t.completed);

    pendingCountEl.textContent = pending.length;
    doneCountEl.textContent = done.length;

    let html = '';

    html += `<div class="section-label pending-label">Pending tasks</div>`;
    if(pending.length === 0){
      html += `<div class="empty-state">Nothing logged yet. Add a task above to get your day started.</div>`;
    } else {
      html += `<ul class="task-list">` + pending.map((t,i) => taskRowHTML(t,i)).join('') + `</ul>`;
    }

    html += `<div class="section-label done-label">Completed tasks</div>`;
    if(done.length === 0){
      html += `<div class="empty-state">Nothing checked off yet — completed tasks will land here.</div>`;
    } else {
      html += `<ul class="task-list">` + done.map((t,i) => taskRowHTML(t,i)).join('') + `</ul>`;
    }

    appBody.innerHTML = html;

    // wire up events
    appBody.querySelectorAll('.task').forEach(li => {
      const id = li.getAttribute('data-id');
      const toggleBtn = li.querySelector('[data-action="toggle"]');
      if(toggleBtn) toggleBtn.addEventListener('click', () => toggleComplete(id));

      const editBtn = li.querySelector('[data-action="edit"]');
      if(editBtn) editBtn.addEventListener('click', () => startEdit(id));

      const delBtn = li.querySelector('[data-action="delete"]');
      if(delBtn) delBtn.addEventListener('click', () => deleteTask(id));

      const saveBtn = li.querySelector('[data-action="save-edit"]');
      const editInput = li.querySelector('[data-action="edit-input"]');
      if(saveBtn && editInput){
        saveBtn.addEventListener('click', () => commitEdit(id, editInput.value));
        editInput.addEventListener('keydown', (e) => {
          if(e.key === 'Enter') commitEdit(id, editInput.value);
          if(e.key === 'Escape') cancelEdit(id);
        });
        editInput.focus();
        editInput.setSelectionRange(editInput.value.length, editInput.value.length);
      }
    });
  }

  addBtn.addEventListener('click', addTask);
  inputEl.addEventListener('keydown', (e) => {
    if(e.key === 'Enter') addTask();
  });

  loadTasks();
})();
</script>
</body>
</html>
